{
    "name": "Qmusic",
    "productName": "Qmusic",
    "version": "2.0.0",
    "description": "聚合音乐播放器",
    "main": ".webpack/main",
    "private": true,
    "scripts": {
        "start": "electron-forge start",
        "dev": "chcp 65001 && electron-forge start --inspect-electron",
        "package": "node -e \"require('fs').rmSync('.webpack',{recursive:true,force:true});require('fs').rmSync('out',{recursive:true,force:true})\" && cross-env NODE_ENV=production ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ electron-forge package",
        "make": "cross-env NODE_ENV=production ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ electron-forge make",
        "build": "cross-env NODE_ENV=production ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ electron-forge make",
        "publish": "electron-forge publish",
        "format": "prettier . --write",
        "format:check": "prettier . --check",
        "lint": "eslint ./src",
        "lint:fix": "eslint ./src --fix",
        "lint-staged": "lint-staged",
        "prepare": "husky"
    },
    "keywords": [
        "music",
        "player",
        "Qmusic",
        "electron",
        "plugin"
    ],
    "homepage": "https://github.com/cnqvnet/Qmusic",
    "repository": {
        "type": "git",
        "url": "https://github.com/cnqvnet/Qmusic.git"
    },
    "bugs": {
        "url": "https://github.com/cnqvnet/Qmusic/issues"
    },
    "author": {
        "name": "",
        "email": "valdo2008@gmail.com"
    },
    "license": "AGPL-3.0-only",
